{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Build",                 // 任务的标签名，launch.json 会通过这个名字来引用它
            "type": "shell",                         // 任务类型是执行 shell 命令
            "command": "cmake",                      // 要执行的命令
            "args": [                                // 命令的参数
                "--build",
                "${workspaceFolder}/build",          // 指向我们之前设置的构建目录
                "--config", "Debug",                 // 指定构建类型为 Debug
                "--parallel", "8"                    // 启用并行编译，加快速度
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc" 
            ]
        }
    ]
}