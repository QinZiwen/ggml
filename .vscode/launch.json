{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "simple-demo",
            "type": "lldb",                           // macOS 上推荐使用 lldb
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/simple-demo", // 调试的可执行文件路径
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: Build",           // 调试前执行的任务名，必须和 tasks.json 里的 label 完全一致
            "console": "integratedTerminal",
        }
    ]
}