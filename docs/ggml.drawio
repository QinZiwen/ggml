t;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;        &lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;void&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt; (*&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;event_record&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;)(&lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;ggml_backend_t&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ffa657;&quot;&gt;backend&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;ggml_backend_event_t&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ffa657;&quot;&gt;event&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #8b949e;&quot;&gt;        // wait for an event on on a different stream&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;        &lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;void&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt; (*&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;event_wait&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;)  (&lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;ggml_backend_t&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ffa657;&quot;&gt;backend&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;ggml_backend_event_t&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ffa657;&quot;&gt;event&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;span style=&quot;color: #8b949e;&quot;&gt;        // (optional) sort/optimize the nodes in the graph&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;        &lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;void&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;                      (*&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;graph_optimize&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;)    (&lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;ggml_backend_t&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ffa657;&quot;&gt;backend&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #ff7b72;&quot;&gt;struct&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #4ec9b0;&quot;&gt;ggml_cgraph&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #569cd6;&quot;&gt;*&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #ffa657;&quot;&gt;cgraph&lt;/span&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;);&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #c9d1d9;&quot;&gt;    };&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
